{
  "config": {
    "step": {
      "user": {
        "title": "HYMER Connect Metadata Login",
        "description": "Enter your HYMER Connect account credentials. Prepare and install the local runtime metadata pack first, then use the same email and password as in the HYMER Connect app.",
        "data": {
          "brand": "Brand",
          "username": "Email",
          "password": "Password"
        }
      },
      "select_vehicle": {
        "title": "Select Vehicle",
        "description": "Choose which vehicle to add as a separate Home Assistant entry. You can add the app-extracted remote access token now or later via Reconfigure.",
        "data": {
          "selected_vehicle": "Vehicle",
          "ehg_refresh_token": "EHG Remote Access Refresh Token (optional)"
        },
        "data_description": {
          "ehg_refresh_token": "Needed for live SignalR telemetry and control. You can leave this blank for now and add it later from the config entry menu."
        }
      },
      "reauth_confirm": {
        "title": "[%key:common::config_flow::title::reauth%]",
        "description": "The HYMER Connect Metadata integration needs to re-authenticate your account.",
        "data": {
          "username": "Email",
          "password": "Password"
        }
      },
      "reconfigure": {
        "title": "Update Remote Access Token",
        "description": "Update the app-extracted EHG remote access refresh token for this vehicle. Leave it blank to remove the stored token.",
        "data": {
          "ehg_refresh_token": "EHG Remote Access Refresh Token"
        }
      }
    },
    "error": {
      "cannot_connect": "Failed to connect to HYMER Connect API",
      "invalid_auth": "Invalid email or password",
      "missing_runtime_metadata": "Prepare and install the local runtime metadata pack before signing in",
      "invalid_remote_access_token": "The remote access token could not be validated for this vehicle",
      "no_vehicles": "No vehicles were found for this account",
      "vehicle_not_found": "The configured vehicle could not be resolved from this account",
      "wrong_account": "The new credentials do not have access to the configured vehicle",
      "unknown": "Unexpected error occurred"
    },
    "abort": {
      "already_configured": "[%key:common::config_flow::abort::already_configured_device%]",
      "reauth_successful": "[%key:common::config_flow::abort::reauth_successful%]",
      "reconfigure_successful": "Reconfiguration was successful"
    }
  },
  "options": {
    "step": {
      "init": {
        "title": "Display And Debug Options",
        "description": "Configure optional debug entities and display units for this vehicle entry.",
        "data": {
          "show_admin_actions": "Show admin actions",
          "show_debug_diagnostics": "Show debug diagnostics",
          "use_miles": "Display distance in miles",
          "use_fahrenheit": "Display temperature in Fahrenheit"
        }
      }
    }
  },
  "issues": {
    "missing_runtime_metadata": {
      "title": "Local HYMER runtime metadata is missing",
      "description": "HYMER Connect Metadata cannot finish setup because the local runtime metadata pack is missing.\n\nMissing files: {missing_files}\n\nFrom a full checkout of this repository on any machine, prepare the metadata pack with:\n```\n{prepare_command}\n```\n\nIf the APK contains a Hermes bytecode bundle, rerun the command with `--bundle-js` or `--bundle-js-url`. Then extract the generated zip into `custom_components/hymer_connect_metadata/data/` inside the Home Assistant config directory and reload the integration."
    }
  },
